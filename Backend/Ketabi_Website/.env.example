# MongoDB Connection
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database>?retryWrites=true&w=majority&appName=<app-name>

# Server Port
PORT=3000

# Encryption Key
ENCRYPTION_KEY=<your_encryption_key>

# App Email Credentials
APP_EMAIL=<your_email@example.com>
APP_PASSWORD=<your_app_password>

# JWT Configuration
JWT_SECRET_KEY=<your_jwt_secret_key>
JWT_EXPIRES_IN=1h

# Redis Configuration
REDIS_URL=redis://localhost:6379/0

# Session Secret
SESSION_SECRET=<your_session_secret>
# Node Environment
NODE_ENV=development
# Stripe Secret Key
STRIPE_SECRET_KEY=<your_stripe_secret_key>
# Optional backend URL used to build downloadable file links
BACKEND_BASE_URL=http://localhost:3000